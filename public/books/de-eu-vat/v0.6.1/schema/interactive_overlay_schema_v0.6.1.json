{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VAT Atlas Interactive Overlay v0.6.1",
  "type": "object",
  "required": [
    "version",
    "pageId",
    "sectionCode",
    "canvas",
    "imageFile",
    "overlayType",
    "sections",
    "gridRegions",
    "imageHotspots",
    "qa"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "pageId": {
      "type": "string"
    },
    "sectionCode": {
      "type": "string"
    },
    "canvas": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "aspect": {
          "type": "string"
        },
        "measurementBasis": {
          "type": "string"
        }
      }
    },
    "imageFile": {
      "type": "string"
    },
    "overlayType": {
      "type": "string"
    },
    "textRegions": {
      "type": "array"
    },
    "sections": {
      "type": "array"
    },
    "gridRegions": {
      "type": "array"
    },
    "imageHotspots": {
      "type": "array"
    },
    "navigationRegions": {
      "type": "array"
    },
    "legalAnchors": {
      "type": "array"
    },
    "interactionHints": {
      "type": "array"
    },
    "qa": {
      "type": "object"
    }
  }
}